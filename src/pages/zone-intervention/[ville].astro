---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Contact from '../../components/Contact.astro';
import { VILLES_DESSERVIES } from '../../config/villes';

export async function getStaticPaths() {
  return VILLES_DESSERVIES.map(ville => ({ params: { ville } }));
}

const { ville } = Astro.params;
const villeFormatee = ville
  .split('-')
  .map(mot => mot.charAt(0).toUpperCase() + mot.slice(1))
  .join(' ');

// Dictionnaire des descriptions personnalisées (top 10 + existantes)
const descriptions: Record<string, string> = {
  // Top 10 prioritaire SEO
  "paris-15": "Diagnostic immobilier dans le 15e arrondissement par un expert certifié DIAGOTOP. DPE, amiante, plomb, électricité dès 120€. Devis gratuit, intervention sous 24h.",
  "boulogne-billancourt": "Votre diagnostic immobilier à Boulogne-Billancourt par DIAGOTOP. Rapport complet sous 48h, valable immédiatement. Devis gratuit, sans engagement.",
  "versailles": "Diagnostics immobiliers obligatoires à Versailles certifiés DIAGOTOP. DPE, amiante, Carrez. Intervention 7j/7, rapport sous 48h. Devis gratuit.",
  "saint-denis": "Expert diagnostic immobilier à Saint-Denis (93). DPE, amiante, plomb, électricité, gaz. Devis gratuit, intervention rapide dans toute la ville. DIAGOTOP certifié.",
