---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Contact from '../../components/Contact.astro';
import { VILLES_DESSERVIES } from '../../config/villes';

export async function getStaticPaths() {
  return VILLES_DESSERVIES.map(ville => ({ params: { ville } }));
}

const { ville } = Astro.params;
const villeFormatee = ville
  .split('-')
  .map(mot => mot.charAt(0).toUpperCase() + mot.slice(1))
  .join(' ');

// Dictionnaire des descriptions personnalisées (top 10 + existantes)
const descriptions: Record<string, string> = {
  // ... (inchangé, gardez votre dictionnaire actuel) ...
};

const descriptionLocale = descriptions[ville] || `DIAGOTOP intervient à ${villeFormatee} et dans toute l'Île-de-France pour vos diagnostics immobiliers (DPE, Amiante, Plomb...). Devis gratuit et rapide.`;

const titleSEO = `Diagnostic immobilier à ${villeFormatee} | DIAGOTOP Île-de-France`;
const descSEO = descriptionLocale;

// Villes proches pour maillage interne
const villesProches = VILLES_DESSERVIES
  .filter(v => v !== ville)
  .sort(() => 0.5 - Math.random())
  .slice(0, 5)
  .map(v => ({
    slug: v,
    nom: v.split('-').map(m => m.charAt(0).toUpperCase() + m.slice(1)).join(' ')
  }));

// Dictionnaire de contenu unique "À propos" pour les 10 villes prioritaires
const aPropos: Record<string, string> = {
  "bezons": "Bezons est une commune du département du Val-d'Oise, en région Île-de-France. Située sur la rive droite de la Seine, elle a la particularité d'être limitrophe de deux départements : les Hauts-de-Seine et les Yvelines. Notre agence DIAGOTOP, basée au 64 rue Francis de Pressensé, connaît parfaitement le marché immobilier local.",
  "argenteuil": "Argenteuil est la commune la plus peuplée du Val-d'Oise. En bord de Seine, elle est connue pour son riche passé industriel et son patrimoine lié aux impressionnistes. Aujourd'hui, son marché immobilier est dynamique, avec de nombreuses résidences récentes et des quartiers en pleine rénovation.",
  "paris-15": "Le 15ème arrondissement de Paris est le plus peuplé de la capitale. Mêlant quartiers résidentiels et zones d'activité, il offre une grande diversité de logements. DIAGOTOP intervient dans tous les quartiers, de Grenelle à Vaugirard.",
  "boulogne-billancourt": "Boulogne-Billancourt est une commune des Hauts-de-Seine, limitrophe de Paris. Importante ville d'affaires et résidentielle, elle abrite de nombreuses entreprises et un parc immobilier varié, des immeubles haussmanniens aux constructions plus récentes.",
  "versailles": "Versailles, célèbre pour son château et son patrimoine historique, est aussi une ville résidentielle très recherchée de l'ouest parisien. Les diagnostics immobiliers y sont fréquents, notamment dans les quartiers Notre-Dame et Saint-Louis.",
  "saint-denis": "Saint-Denis, en Seine-Saint-Denis, est une ville en pleine transformation. Entre la basilique, le Stade de France et les nouveaux quartiers, le marché immobilier est très actif, avec de nombreuses ventes et locations.",
  "nanterre": "Nanterre, préfecture des Hauts-de-Seine, est un pôle économique majeur avec le quartier d'affaires de La Défense. La ville mêle immeubles modernes et zones pavillonnaires, nécessitant des diagnostics variés.",
  "creteil": "Créteil, préfecture du Val-de-Marne, est connue pour son lac et son architecture moderne. Le marché immobilier y est dynamique, avec une forte proportion de copropriétés.",
  "montreuil": "Montreuil, en Seine-Saint-Denis, est une ville résidentielle et populaire, avec un parc immobilier ancien et de nombreux projets de rénovation. Les diagnostics plomb et amiante y sont courants.",
  "aulnay-sous-bois": "Aulnay-sous-Bois, en Seine-Saint-Denis, est une commune résidentielle au nord-est de Paris. Elle compte de nombreux pavillons et des quartiers en développement, où les diagnostics électricité et gaz sont fréquents."
};

const textePropos = aPropos[ville] || `${villeFormatee} est une commune d'Île-de-France. Notre équipe de diagnostiqueurs certifiés connaît bien cette ville et intervient rapidement pour tous vos diagnostics immobiliers obligatoires.`;
---

<BaseLayout title={titleSEO} description={descSEO}>
  <section class="section" style="padding-top: 140px;">
    <div class="container">
      <!-- Fil d'Ariane SEO -->
      <nav aria-label="Fil d'ariane" style="margin-bottom: 24px; font-size: 14px; color: var(--muted);">
        <a href="/">Accueil</a> &rsaquo; <a href="/zones-intervention">Zones d'intervention</a> &rsaquo; <span>{villeFormatee}</span>
      </nav>

      <div class="text-center">
        <div class="tag">📍 Zone d'intervention</div>
        <h1>Diagnostic immobilier à <span class="grad">{villeFormatee}</span></h1>
        <p class="section-sub">{descriptionLocale}</p>
      </div>

      <!-- Grille des diagnostics proposés -->
      <div class="diag-grid" style="margin-top: 48px;">
        <div class="diag-card"><div class="diag-icon">⚡</div><div class="diag-title">DPE</div><div class="diag-sub">Performance Énergétique</div><div class="diag-price">Dès 120 €</div></div>
        <div class="diag-card"><div class="diag-icon">🛡️</div><div class="diag-title">Amiante</div><div class="diag-sub">Avant 1997</div><div class="diag-price">Dès 150 €</div></div>
        <div class="diag-card"><div class="diag-icon">⚠️</div><div class="diag-title">Plomb</div><div class="diag-sub">Avant 1949</div><div class="diag-price">Dès 100 €</div></div>
        <div class="diag-card"><div class="diag-icon">🔌</div><div class="diag-title">Électricité</div><div class="diag-sub">+15 ans</div><div class="diag-price">Dès 110 €</div></div>
      </div>

      <!-- Avantages locaux -->
      <div style="margin-top: 60px; background: var(--bg); padding: 40px; border-radius: 24px;">
        <h2 style="text-align: center; margin-bottom: 32px;">Pourquoi choisir DIAGOTOP à {villeFormatee} ?</h2>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
          <div style="text-align: center;">
            <div style="font-size: 32px; margin-bottom: 12px;">🚗</div>
            <h3>Intervention rapide</h3>
            <p>Déplacement sous 24h dans tout {villeFormatee} et les communes limitrophes.</p>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 32px; margin-bottom: 12px;">📋</div>
            <h3>Rapport certifié</h3>
            <p>Documents conformes à la réglementation, valables immédiatement.</p>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 32px; margin-bottom: 12px;">⭐</div>
            <h3>Recommandé</h3>
            <p>Plus de 500 clients satisfaits en Île-de-France.</p>
          </div>
        </div>
      </div>

      <!-- Paragraphe unique sur la ville -->
      <div style="margin-top: 48px;">
        <h2 style="margin-bottom: 16px;">À propos de {villeFormatee}</h2>
        <p style="color: var(--muted); line-height: 1.6;">{textePropos}</p>
      </div>

      <!-- FAQ Dynamique complète -->
      <div style="margin-top: 60px;">
        <h2 style="text-align: center; margin-bottom: 32px;">Tout savoir sur les diagnostics immobiliers à {villeFormatee}</h2>
        <div style="max-width: 800px; margin: 0 auto;">

          <!-- DPE -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">⚡ En quoi consiste le DPE ?</h3>
            <p style="color: var(--muted);">Le Diagnostic de Performance Énergétique (DPE) évalue la consommation d'énergie et les émissions de gaz à effet de serre d'un logement. Il est obligatoire pour toute vente ou location. Sa durée de validité est de 10 ans pour les DPE réalisés après le 1er juillet 2021.</p>
          </div>

          <!-- Amiante -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🛡️ Quand le diagnostic amiante est-il obligatoire ?</h3>
            <p style="color: var(--muted);">Il est exigé pour tout bien dont le permis de construire a été délivré avant le 1er juillet 1997. Il est valable 3 ans en cas de présence d'amiante, et illimité si aucun matériau amianté n'est détecté.</p>
          </div>

          <!-- Plomb -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">⚠️ Qui est concerné par le diagnostic plomb (CREP) ?</h3>
            <p style="color: var(--muted);">Le Constat de Risque d'Exposition au Plomb (CREP) concerne les logements construits avant le 1er janvier 1949. En cas de vente, il est valable 1 an ; pour une location, il est valable 6 ans s'il révèle la présence de plomb.</p>
          </div>

          <!-- Électricité -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🔌 Quand fournir un diagnostic électrique ?</h3>
            <p style="color: var(--muted);">Il est obligatoire pour toute installation électrique de plus de 15 ans. Sa durée de validité est de 3 ans pour une vente, et de 6 ans pour une location.</p>
          </div>

          <!-- Gaz -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🔥 Et le diagnostic gaz ?</h3>
            <p style="color: var(--muted);">Il s'applique aux installations de gaz de plus de 15 ans. Comme pour l'électricité, il est valable 3 ans (vente) ou 6 ans (location).</p>
          </div>

          <!-- Termites -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🐛 Dans quelles zones le diagnostic termites est-il exigé ?</h3>
            <p style="color: var(--muted);">Il est obligatoire uniquement en cas de vente, et seulement si la commune est déclarée infestée par un arrêté préfectoral. Sa validité est de 6 mois.</p>
          </div>

          <!-- Mesurage -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">📐 À quoi sert le mesurage loi Carrez ?</h3>
            <p style="color: var(--muted);">Il certifie la surface privative d'un lot de copropriété. Obligatoire lors de la vente, il est valable sans limitation de durée, sauf si la surface est modifiée par des travaux.</p>
          </div>

          <!-- État des risques -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">📍 L'état des risques est-il obligatoire partout ?</h3>
            <p style="color: var(--muted);">Oui, pour toutes les ventes et locations. Il informe sur les risques naturels, miniers, technologiques, sismiques, etc. Sa durée de validité est de 6 mois.</p>
          </div>

          <!-- Audit énergétique -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🏠 Qui est concerné par l'audit énergétique ?</h3>
            <p style="color: var(--muted);">Il est obligatoire pour les propriétaires de maisons individuelles ou d'immeubles en monopropriété classés F ou G au DPE, lors de la mise en vente. Il propose des scénarios de travaux pour améliorer la performance énergétique. Sa validité est de 5 ans.</p>
          </div>

          <!-- Obligations vente / location -->
          <div style="background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 24px; margin-bottom: 16px;">
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🏘️ Quels diagnostics pour une vente ? Et pour une location ?</h3>
            <p style="color: var(--muted);">
              <strong>Vente :</strong> DPE, amiante (avant 1997), plomb (avant 1949), électricité (+15 ans), gaz (+15 ans), termites (si arrêté préfectoral), état des risques, mesurage Carrez (copropriété).<br/>
              <strong>Location :</strong> DPE, plomb (avant 1949, 6 ans si présent), électricité (+15 ans), gaz (+15 ans), état des risques, amiante (avant 1997).
            </p>
          </div>

        </div>
      </div>

      <!-- Villes proches (maillage interne) -->
      {villesProches.length > 0 && (
        <div style="margin-top: 48px; text-align: center;">
          <h2 style="margin-bottom: 24px;">Diagnostics immobiliers à proximité</h2>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;">
            {villesProches.map(v => (
              <a href={`/zone-intervention/${v.slug}`} style="background: var(--bg); padding: 8px 16px; border-radius: 20px; font-size: 14px; color: var(--black); text-decoration: none; transition: all 0.2s;">
                {v.nom}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Appel à l'action -->
      <div style="text-align: center; margin-top: 48px;">
        <a href="/#contact" class="btn btn-primary" style="padding: 18px 40px;">📞 Obtenir un devis gratuit à {villeFormatee}</a>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Contact />
</BaseLayout>

<style>
  .diag-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .diag-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid var(--border);
    text-align: center;
  }
  .diag-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(245,166,35,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin: 0 auto 16px;
  }
  .diag-title { font-weight: 800; margin-bottom: 4px; }
  .diag-sub { font-size: 12px; color: var(--muted); margin-bottom: 12px; }
  .diag-price { font-weight: 700; color: var(--gold); }
  @media (max-width: 768px) {
    .diag-grid { grid-template-columns: 1fr; }
  }
</style>