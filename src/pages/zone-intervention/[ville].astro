  "savigny-le-temple": "Diagnostics immobiliers à Savigny-le-Temple et Sénart. Expert certifié, intervention rapide.",
  "bussy-saint-georges": "Votre expert en diagnostics à Bussy-Saint-Georges et Marne-la-Vallée. Rapport sous 48h.",
  "dammarie-les-lys": "Diagnostics à Dammarie-les-Lys, Melun sud. Service professionnel pour vos ventes et locations.",
  "torcy": "Intervention pour diagnostics à Torcy et alentours (Val Maubuée). Devis gratuit et rapide.",
  "combs-la-ville": "Diagnostics immobiliers à Combs-la-Ville et secteur de la Brie centrale. Expert certifié.",
  "montereau-fault-yonne": "Diagnostics à Montereau-Fault-Yonne et ses environs (confluence Seine-Yonne). Intervention rapide.",

  // Yvelines (78)
  "sartrouville": "Expert en diagnostics à Sartrouville et la boucle de Montesson. Devis gratuit, intervention rapide.",
  "saint-germain-en-laye": "Diagnostics DPE, Amiante, Plomb à Saint-Germain-en-Laye et sa région. Rapport certifié sous 48h.",
  "mantes-la-jolie": "Intervention pour diagnostics à Mantes-la-Jolie et Mantes-la-Ville. Service rapide dans le Mantois.",
  "poissy": "Diagnostics immobiliers à Poissy et Carrières-sous-Poissy. Expert certifié à votre disposition.",
  "conflans-sainte-honorine": "Diagnostics à Conflans-Sainte-Honorine et la confluence Seine-Oise. Devis en ligne immédiat.",
  "rambouillet": "Votre diagnostiqueur certifié à Rambouillet et sa région. Intervention dans le sud des Yvelines.",

  // Essonne (91)
  "evry-courcouronnes": "Diagnostics immobiliers à Évry-Courcouronnes et l'agglomération d'Évry. Expert certifié, rapport rapide.",
  "corbeil-essonnes": "Intervention pour diagnostics à Corbeil-Essonnes et ses environs. Service professionnel.",
  "massy": "Diagnostics DPE, Amiante, Plomb à Massy et Antony. Devis gratuit et intervention rapide.",
  "savigny-sur-orge": "Votre expert en diagnostics à Savigny-sur-Orge et la vallée de l'Orge. Rapport sous 48h.",
  "athis-mons": "Diagnostics immobiliers à Athis-Mons et Juvisy-sur-Orge. Service de proximité.",
  "juvisy-sur-orge": "Intervention pour diagnostics à Juvisy-sur-Orge et alentours. Expert certifié.",
  "grigny": "Diagnostics à Grigny et la Grande Borne. Service rapide pour vos ventes et locations.",
  "sainte-genevieve-des-bois": "Diagnostics immobiliers à Sainte-Geneviève-des-Bois et le secteur du Val d'Orge.",

  // Hauts-de-Seine (92)
  "asnieres-sur-seine": "Diagnostics DPE, Amiante, Plomb à Asnières-sur-Seine et la boucle nord des Hauts-de-Seine.",
  "colombes": "Intervention pour diagnostics à Colombes et Bois-Colombes. Service professionnel et certifié.",
  "courbevoie": "Diagnostics immobiliers à Courbevoie et La Défense. Expert à votre disposition.",
  "rueil-malmaison": "Diagnostics à Rueil-Malmaison : quartiers historiques, bords de Seine. Devis gratuit.",
  "levallois-perret": "Votre diagnostiqueur certifié à Levallois-Perret. Intervention rapide en cœur de ville.",
  "clichy": "Diagnostics immobiliers à Clichy et ses environs. Service de qualité pour vos transactions.",
  "montrouge": "Expert en diagnostics à Montrouge et le sud de Paris. Rapport certifié sous 48h.",

  // Seine-Saint-Denis (93)
  "aubervilliers": "Diagnostics DPE, Amiante, Plomb à Aubervilliers et La Plaine Saint-Denis. Expert certifié.",
  "drancy": "Diagnostics immobiliers à Drancy et Le Bourget. Service professionnel, rapport sous 48h.",
  "noisy-le-grand": "Expert en diagnostics à Noisy-le-Grand et Porte de Paris. Devis en ligne immédiat.",
  "pantin": "Diagnostics à Pantin : Quatre Chemins, Église, Courtillières. Intervention 7j/7.",
  "le-blanc-mesnil": "Diagnostics immobiliers au Blanc-Mesnil et ses environs. Service de proximité.",
  "bobigny": "Intervention pour diagnostics à Bobigny et la Préfecture de Seine-Saint-Denis.",

  // Val-de-Marne (94)
  "vitry-sur-seine": "Diagnostics immobiliers à Vitry-sur-Seine et ses quartiers en pleine mutation. Expert certifié.",
  "champigny-sur-marne": "Intervention pour diagnostics à Champigny-sur-Marne et la boucle de la Marne.",
  "saint-maur-des-fosses": "Diagnostics à Saint-Maur-des-Fossés : La Varenne, Adamville, Le Parc. Service haut de gamme.",
  "ivry-sur-seine": "Votre diagnostiqueur certifié à Ivry-sur-Seine et le 13ème arrondissement limitrophe.",
  "maisons-alfort": "Diagnostics immobiliers à Maisons-Alfort et Alfortville. Rapport rapide et fiable.",
  "villejuif": "Expert en diagnostics à Villejuif et le sud de Paris. Intervention rapide.",
  "vincennes": "Expert en diagnostics immobiliers à Vincennes et aux alentours (Fontenay, Saint-Mandé). Intervention rapide.",

  // Val-d'Oise (95)
  "cergy": "Intervention pour diagnostics à Cergy et Cergy-Pontoise. Expert certifié à votre service.",
  "sarcelles": "Diagnostics DPE, Amiante, Plomb à Sarcelles et Villiers-le-Bel. Rapport sous 48h.",
  "garges-les-gonesse": "Votre diagnostiqueur certifié à Garges-lès-Gonesse et Arnouville. Service de proximité.",
  "franconville": "Diagnostics immobiliers à Franconville et la vallée de Montmorency. Intervention rapide.",
  "pontoise": "Diagnostics à Pontoise et sa région. Service professionnel pour vos transactions immobilières.",
  "herblay-sur-seine": "Diagnostics immobiliers à Herblay-sur-Seine et La Frette-sur-Seine. Rapport certifié."
};

const descriptionLocale = descriptions[ville] || `DIAGOTOP intervient à ${villeFormatee} et dans toute l'Île-de-France pour vos diagnostics immobiliers (DPE, Amiante, Plomb...). Devis gratuit et rapide.`;

const titleSEO = `Diagnostic immobilier à ${villeFormatee} | DIAGOTOP Île-de-France`;
const descSEO = descriptionLocale;

// Villes proches pour maillage interne (logique simplifiée)
const villesProches = VILLES_DESSERVIES
  .filter(v => v !== ville)
  .sort(() => 0.5 - Math.random())
  .slice(0, 5)
  .map(v => ({
    slug: v,
    nom: v.split('-').map(m => m.charAt(0).toUpperCase() + m.slice(1)).join(' ')
  }));
---

<BaseLayout title={titleSEO} description={descSEO}>
  <section class="section" style="padding-top: 140px;">
    <div class="container">
      <!-- Fil d'Ariane SEO -->
      <nav aria-label="Fil d'ariane" style="margin-bottom: 24px; font-size: 14px; color: var(--muted);">
        <a href="/">Accueil</a> &rsaquo; <a href="/zones-intervention">Zones d'intervention</a> &rsaquo; <span>{villeFormatee}</span>
      </nav>

      <div class="text-center">
        <div class="tag">📍 Zone d'intervention</div>
        <h1>Diagnostic immobilier à <span class="grad">{villeFormatee}</span></h1>
        <p class="section-sub">{descriptionLocale}</p>
      </div>

      <!-- Grille des diagnostics proposés -->
      <div class="diag-grid" style="margin-top: 48px;">
        <div class="diag-card"><div class="diag-icon">⚡</div><div class="diag-title">DPE</div><div class="diag-sub">Performance Énergétique</div><div class="diag-price">Dès 120 €</div></div>
        <div class="diag-card"><div class="diag-icon">🛡️</div><div class="diag-title">Amiante</div><div class="diag-sub">Avant 1997</div><div class="diag-price">Dès 150 €</div></div>
        <div class="diag-card"><div class="diag-icon">⚠️</div><div class="diag-title">Plomb</div><div class="diag-sub">Avant 1949</div><div class="diag-price">Dès 100 €</div></div>
        <div class="diag-card"><div class="diag-icon">🔌</div><div class="diag-title">Électricité</div><div class="diag-sub">+15 ans</div><div class="diag-price">Dès 110 €</div></div>
      </div>

      <!-- Avantages locaux -->
      <div style="margin-top: 60px; background: var(--bg); padding: 40px; border-radius: 24px;">
        <h2 style="text-align: center; margin-bottom: 32px;">Pourquoi choisir DIAGOTOP à {villeFormatee} ?</h2>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
          <div style="text-align: center;">
            <div style="font-size: 32px; margin-bottom: 12px;">🚗</div>
            <h3>Intervention rapide</h3>
            <p>Déplacement sous 24h dans tout {villeFormatee} et les communes limitrophes.</p>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 32px; margin-bottom: 12px;">📋</div>
            <h3>Rapport certifié</h3>
            <p>Documents conformes à la réglementation, valables immédiatement.</p>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 32px; margin-bottom: 12px;">⭐</div>
            <h3>Recommandé</h3>
            <p>Plus de 500 clients satisfaits en Île-de-France.</p>
          </div>
        </div>
      </div>

      <!-- Villes proches (maillage interne) -->
      {villesProches.length > 0 && (
        <div style="margin-top: 48px; text-align: center;">
          <h2 style="margin-bottom: 24px;">Diagnostics immobiliers à proximité</h2>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;">
            {villesProches.map(v => (
              <a href={`/zone-intervention/${v.slug}`} style="background: var(--bg); padding: 8px 16px; border-radius: 20px; font-size: 14px; color: var(--black); text-decoration: none; transition: all 0.2s;">
                {v.nom}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Appel à l'action -->
      <div style="text-align: center; margin-top: 48px;">
        <a href="/#contact" class="btn btn-primary" style="padding: 18px 40px;">📞 Obtenir un devis gratuit à {villeFormatee}</a>
      </div>
    </div>
  </section>

  <CtaBanner />
  <Contact />
</BaseLayout>

<style>
  .diag-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .diag-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid var(--border);
    text-align: center;
  }
  .diag-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(245,166,35,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin: 0 auto 16px;
  }
  .diag-title { font-weight: 800; margin-bottom: 4px; }
  .diag-sub { font-size: 12px; color: var(--muted); margin-bottom: 12px; }
  .diag-price { font-weight: 700; color: var(--gold); }
  @media (max-width: 768px) {
    .diag-grid { grid-template-columns: 1fr; }
  }
</style>