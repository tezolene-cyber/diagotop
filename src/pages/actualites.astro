---
import BaseLayout from '../layouts/BaseLayout.astro';
import articles from '../data/selected-articles.json';
---

<BaseLayout
  title="Actualités du Diagnostic Immobilier | DIAGOTOP"
  description="Les articles sélectionnés par DIAGOTOP pour suivre l'actualité réglementaire et technique du diagnostic immobilier."
>
  <section class="section" style="padding-top: 140px;">
    <div class="container">
      <h1>📰 Actualités du Diagnostic Immobilier</h1>
      <p class="section-sub">Les articles sélectionnés par notre équipe pour vous informer</p>

      <div class="news-grid">
        {articles.map((article) => (
          <article class="news-card">
            <div class="news-meta">
              <span class="news-source">{article.source}</span>
              <time datetime={article.pubDate}>
                {new Date(article.pubDate).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
            <h2 class="news-title">
              <a href={article.link} target="_blank" rel="noopener noreferrer">
                {article.title}
              </a>
            </h2>
            <p class="news-desc">{article.description?.slice(0, 300)}...</p>
            <a href={article.link} class="btn btn-outline" style="margin-top:16px;" target="_blank" rel="noopener noreferrer">
              Lire l'article complet →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }
  .news-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .news-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .news-source {
    background: rgba(245,166,35,0.12);
    color: var(--gold);
    padding: 2px 10px;
    border-radius: 12px;
    font-weight: 600;
  }
  .news-title {
    font-size: 18px;
    font-weight: 800;
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .news-title a {
    color: var(--black);
    text-decoration: none;
  }
  .news-title a:hover {
    color: var(--gold);
  }
  .news-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
