---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchActualites } from '../lib/rpdi-parser.js';
import fallbackArticles from '../data/selected-articles.json';

let articles = await fetchActualites();
// Si le fetch échoue ou ne renvoie rien, on utilise le fallback
if (!articles || articles.length === 0) {
  articles = fallbackArticles;
}
---

<BaseLayout title="Actualités du diagnostic immobilier – DIAGOTOP">
  <div class="container" style="padding: 120px 24px 60px;">
    <h1>Actualités du diagnostic immobilier</h1>
    <p class="section-sub">Les dernières informations de la profession, sélectionnées pour vous.</p>

    <div class="actualites-grid">
      {articles.map((article, i) => (
        <article class="actualite-card">
          <div class="actualite-content">
            <div class="actualite-source">{article.source}</div>
            <h2 class="actualite-title">
              <a href={article.url} target="_blank" rel="noopener">{article.titre}</a>
            </h2>
            {article.date && <time class="actualite-date">{article.date}</time>}
          </div>
        </article>
      ))}
    </div>

    <p style="margin-top: 32px; font-size: 14px; color: var(--muted);">
      Source : <a href="https://www.rpdi.fr" target="_blank" rel="noopener">RPDI.fr</a> – Les actualités sont chargées automatiquement lors de chaque mise à jour du site.
    </p>
  </div>
</BaseLayout>

<style>
  .actualites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 32px;
  }
  .actualite-card {
    background: white;
    border-radius: 18px;
    padding: 24px;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .actualite-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .actualite-source {
    display: inline-block;
    background: var(--navy);
    color: var(--gold);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 12px;
  }
  .actualite-title {
    font-size: 18px;
    font-weight: 800;
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .actualite-title a {
    color: var(--black);
    text-decoration: none;
  }
  .actualite-title a:hover {
    color: var(--gold);
  }
  .actualite-date {
    font-size: 13px;
    color: var(--muted);
  }
</style>