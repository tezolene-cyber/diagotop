---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchActualites } from '../lib/rpdi-parser.js';
import fallbackArticles from '../data/selected-articles.json';

let articles = await fetchActualites();
if (!articles || articles.length === 0) {
  articles = fallbackArticles;
}
---

<BaseLayout title="Actualités du diagnostic immobilier – DIAGOTOP">
  <div class="container" style="padding: 120px 24px 60px;">
    <h1>Actualités du diagnostic immobilier</h1>
    <p class="section-sub">Les dernières informations de la profession, sélectionnées pour vous.</p>

    <div class="actualites-grid">
      {articles.map((article, i) => (
        <article class="actualite-card">
          {article.image && (
            <div class="actualite-image">
              <img src={article.image} alt="" loading="lazy" />
            </div>
          )}
          <div class="actualite-content">
            <div class="actualite-source">{article.source}</div>
            <h2 class="actualite-title">
              <a href={article.url} target="_blank" rel="noopener">{article.titre}</a>
            </h2>
            {article.date && <time class="actualite-date">{article.date}</time>}
          </div>
        </article>
      ))}
    </div>

  </div>

  <!-- Données structurées pour les articles (Google Actualités) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": articles.map(a => ({
      "@type": "Article",
      "headline": a.titre,
      "url": a.url,
      "datePublished": a.date,
      "sourceOrganization": {
        "@type": "Organization",
        "name": a.source
      }
    }))
  })} />
</BaseLayout>