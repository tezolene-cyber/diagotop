<section id="contact" class="section section-alt">
  <div class="container">
    <!-- ... tout le contenu HTML reste inchangé ... -->
  </div>
</section>

<script>
  // Chargement différé d'EmailJS – depuis notre serveur (cache longue durée)
  function loadEmailJS(callback) {
    if (window.emailjs) {
      callback();
      return;
    }
    const script = document.createElement('script');
    script.src = '/js/email.min.js';  // 🔥 Changé de CDN à local
    script.onload = callback;
    document.head.appendChild(script);
  }

  const form = document.getElementById('devis-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    loadEmailJS(() => {
      emailjs.init("GpQFvsgpHzOGz2OJw");

      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const message = document.getElementById('message').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const propertyType = document.getElementById('property_type').value;

      if (!name || !email || !message) {
        alert('Veuillez remplir les champs obligatoires.');
        return;
      }

      const templateParams = {
        from_name: name,
        from_email: email,
        phone: phone,
        property_type: propertyType,
        message: message
      };

      emailjs.send('service_8dwst1h', 'template_o02thia', templateParams)
        .then(() => {
          document.querySelector('.form-body').classList.add('hide');
          document.getElementById('form-success').classList.add('show');
        })
        .catch((err) => {
          alert('Erreur lors de l\'envoi. Veuillez réessayer.');
          console.error('EmailJS error:', err);
        });
    });
  });
</script>