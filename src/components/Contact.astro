---
---
<section id="contact" class="section section-alt">
  <div class="container">
    <div class="text-center">
      <div class="tag anim">
        <span aria-hidden="true">✉️</span> Contact
      </div>
      <h2 class="anim">Demandez votre devis gratuit</h2>
      <p class="section-sub anim">Réponse garantie sous 2 heures. Sans engagement.</p>
    </div>
    <div class="contact-grid">
      <div class="contact-info anim">
        <div class="info-card">
          <div class="info-icon" role="img" aria-label="Téléphone"><span aria-hidden="true">📞</span></div>
          <div><div class="info-label">Téléphone</div><div class="info-val">06 99 00 48 75</div></div>
        </div>
        <div class="info-card">
          <div class="info-icon" role="img" aria-label="Email"><span aria-hidden="true">✉️</span></div>
          <div><div class="info-label">Email</div><div class="info-val">diagotop.france@outlook.fr</div></div>
        </div>
        <div class="info-card">
          <div class="info-icon" role="img" aria-label="Zone d'intervention"><span aria-hidden="true">📍</span></div>
          <div><div class="info-label">Zone d'intervention</div><div class="info-val">Île-de-France</div></div>
        </div>
        <div class="info-card">
          <div class="info-icon" role="img" aria-label="Disponibilité"><span aria-hidden="true">🕐</span></div>
          <div><div class="info-label">Disponibilité</div><div class="info-val">Lun–Sam · 8h–19h</div></div>
        </div>
      </div>
      <div class="form-card anim">
        <div class="form-body">
          <form id="devis-form">
            <!-- Champ honeypot invisible -->
            <div style="position:absolute;left:-9999px;" aria-hidden="true">
              <label for="honeypot">Laissez ce champ vide</label>
              <input type="text" id="honeypot" name="honeypot" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="name">Nom complet *</label>
                <input type="text" id="name" name="name" required />
              </div>
              <div class="form-group">
                <label for="phone">Téléphone</label>
                <input type="tel" id="phone" name="phone" />
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="mission_type">Type de mission</label>
                <select id="mission_type" name="mission_type">
                  <option value="">Sélectionnez...</option>
                  <option>Vente</option>
                  <option>Location</option>
                  <option>Travaux / Rénovation</option>
                  <option>Audit énergétique</option>
                  <option>Autre</option>
                </select>
              </div>
              <div class="form-group">
                <label for="surface">Surface approximative (m²)</label>
                <input type="number" id="surface" name="surface" placeholder="Ex: 65" />
              </div>
            </div>
            <div class="form-group">
              <label for="heating_type">Type de chauffage</label>
              <select id="heating_type" name="heating_type">
                <option value="">Sélectionnez...</option>
                <option>Électrique</option>
                <option>Gaz</option>
                <option>Fioul</option>
                <option>Pompe à chaleur (PAC)</option>
                <option>Autre</option>
              </select>
            </div>

            <div class="form-group">
              <label for="property_type">Type de bien</label>
              <select id="property_type" name="property_type">
                <option value="">Sélectionnez...</option>
                <option>Appartement</option>
                <option>Maison individuelle</option>
                <option>Local commercial</option>
                <option>Immeuble / copropriété</option>
                <option>Autre</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" rows="4" placeholder="Décrivez votre besoin (adresse, surface, diagnostics souhaités...)" required></textarea>
            </div>
            <div class="form-group">
              <label style="display:flex;align-items:flex-start;gap:8px;font-weight:normal;">
                <input type="checkbox" name="rgpd" required style="width:auto;margin-top:2px;" />
                <span>J'accepte que mes données soient utilisées pour être recontacté(e). <a href="/confidentialite" target="_blank" style="color:var(--gold);">Politique de confidentialité</a></span>
              </label>
            </div>
            <button type="submit" class="btn btn-primary form-submit" aria-label="Envoyer ma demande de devis">
              <span aria-hidden="true">✈</span> Envoyer ma demande
            </button>
            <p class="form-note">* Champs obligatoires. Devis gratuit et sans engagement.</p>
          </form>
        </div>
        <div class="form-success" id="form-success">
          <div class="success-icon">✅</div>
          <div class="success-title">Message envoyé !</div>
          <p class="success-sub">Nous vous répondrons dans les meilleurs délais.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function loadEmailJS(callback) {
    if (window.emailjs) {
      callback();
      return;
    }
    const script = document.createElement('script');
    script.src = '/js/email.min.js';
    script.onload = callback;
    document.head.appendChild(script);
  }

  const form = document.getElementById('devis-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const honeypot = document.getElementById('honeypot');
    if (honeypot && honeypot.value.trim() !== '') {
      document.querySelector('.form-body').classList.add('hide');
      document.getElementById('form-success').classList.add('show');
      return;
    }

    loadEmailJS(() => {
      emailjs.init("GpQFvsgpHzOGz2OJw");

      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const message = document.getElementById('message').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const propertyType = document.getElementById('property_type').value;
      const missionType = document.getElementById('mission_type').value;
      const surface = document.getElementById('surface').value.trim();
      const heatingType = document.getElementById('heating_type').value;

      if (!name || !email || !message) {
        alert('Veuillez remplir les champs obligatoires.');
        return;
      }

      const templateParams = {
        from_name: name,
        from_email: email,
        phone: phone,
        property_type: propertyType,
        mission_type: missionType,
        surface: surface,
        heating_type: heatingType,
        message: message
      };

      emailjs.send('service_8dwst1h', 'template_o02thia', templateParams)
        .then(() => {
          document.querySelector('.form-body').classList.add('hide');
          document.getElementById('form-success').classList.add('show');
        })
        .catch((err) => {
          alert('Erreur lors de l\'envoi. Veuillez réessayer.');
          console.error('EmailJS error:', err);
        });
    });
  });
</script>