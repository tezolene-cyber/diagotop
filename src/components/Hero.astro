---
---
<section id="hero">
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="tag anim">🛡 Certifiés par l'État</div>
        <h1 class="hero-title anim">Diagnostics <br>Immobiliers <br><span class="grad">Certifiés</span></h1>
        <p class="hero-desc anim">DPE, Amiante, Plomb, Électricité et plus. Intervention dans toute l'<strong>Île-de-France</strong>. Rapport sous 48h, disponible 6j/7.</p>
        <div class="hero-btns anim">
          <a href="#contact" class="btn btn-primary">Obtenir un Devis →</a>
          <a href="#diagnostics" class="btn btn-outline">Nos Diagnostics</a>
        </div>
        <div class="hero-trust anim">
          <div class="trust-item"><span class="trust-check">✓</span> +5000 diagnostics</div>
          <div class="trust-item"><span class="trust-check">✓</span> Disponible 6j/7</div>
          <div class="trust-item"><span class="trust-check">✓</span> Rapport sous 48h</div>
        </div>
      </div>

      <div class="anim">
        <div class="dpe-card">
          <!-- Logo conservé en haut -->
          <img src="/img/logo.jpg" alt="DIAGOTOP" width="200" height="80" fetchpriority="high" />

          <!-- Barres DPE (7 classes) – couleurs flashy -->
          <div class="dpe-bar-row"><span class="dpe-letter" style="color:#00E676;">A</span><div class="dpe-bar" style="width:88%;background:#00E676;">Très performant</div></div>
          <div class="dpe-bar-row"><span class="dpe-letter" style="color:#76FF03;">B</span><div class="dpe-bar" style="width:76%;background:#76FF03;">Performant</div></div>
          <div class="dpe-bar-row"><span class="dpe-letter" style="color:#FFEA00;">C</span><div class="dpe-bar" style="width:64%;background:#FFEA00;">Assez bon</div></div>
          <div class="dpe-bar-row"><span class="dpe-letter" style="color:#FF9100;">D</span><div class="dpe-bar" style="width:52%;background:#FF9100;">Peu efficace</div></div>
          <div class="dpe-bar-row"><span class="dpe-letter" style="color:#FF3D00;">E</span><div class="dpe-bar" style="width:40%;background:#FF3D00;">Énergivore</div></div>
          <div class="dpe-bar-row"><span class="dpe-letter" style="color:#DD0000;">F</span><div class="dpe-bar" style="width:28%;background:#DD0000;">Très énergivore</div></div>
          <div class="dpe-bar-row"><span class="dpe-letter" style="color:#8B0000;">G</span><div class="dpe-bar" style="width:16%;background:#8B0000;">Passoire</div></div>
        </div>
      </div>
    </div>
  </div>
</section>