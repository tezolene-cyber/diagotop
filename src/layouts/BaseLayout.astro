---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const ga4Id = import.meta.env.PUBLIC_GA4_ID || 'G-193H6KEEYR';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <link rel="preload" as="image" href="/img/logo-optimized.png?v=3" fetchpriority="high" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:image" content="/img/logo.png?v=2" />
  <meta name="robots" content="index, follow" />
  <link rel="icon" type="image/png" href="/img/logo.png?v=2" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Polices Inter auto-hébergées (essentielles uniquement) -->
  <link rel="preload" href="/fonts/inter-v20-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-v20-latin-700.woff2" as="font" type="font/woff2" crossorigin />
  <style>
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/fonts/inter-v20-latin-regular.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Inter';
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url('/fonts/inter-v20-latin-700.woff2') format('woff2');
    }
  </style>

  <!-- Données structurées WebSite + LocalBusiness -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "DIAGOTOP",
      "alternateName": "Diagotop",
      "url": "https://www.diagotop.fr"
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "DIAGOTOP – Audit & Diagnostic",
      "description": "Expert certifié en diagnostics immobiliers en Île-de-France",
      "url": "https://www.diagotop.fr",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.diagotop.fr/img/logo.png?v=2",
        "width": 512,
        "height": 512
      },
      "image": {
        "@type": "ImageObject",
        "url": "https://www.diagotop.fr/img/logo.png?v=2",
        "width": 512,
        "height": 512
      },
      "telephone": "06 99 00 48 75",
      "email": "diagotop.france@outlook.fr",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "64 Rue Francis de Pressensé",
        "addressLocality": "Bezons",
        "addressRegion": "Île-de-France",
        "postalCode": "95870",
        "addressCountry": "FR"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Île-de-France"
      },
      "priceRange": "€€",
      "sameAs": [
        "https://www.diagotop.fr"
      ]
    }
  </script>

  <!-- Optimisation : chargement non bloquant des CSS générés par Astro -->
  <script is:inline>
    (function() {
      var links = document.querySelectorAll('link[rel="stylesheet"]');
      links.forEach(function(link) {
        var href = link.href;
        if (href && link.media !== 'print') {
          var preload = document.createElement('link');
          preload.rel = 'preload';
          preload.as = 'style';
          preload.href = href;
          preload.onload = function() {
            this.rel = 'stylesheet';
          };
          link.parentNode.replaceChild(preload, link);
        }
      });
    })();
  </script>
</head>
<body>
  <div id="top-sentinel" aria-hidden="true" style="position: absolute; top: 0; left: 0; height: 1px; width: 100%; pointer-events: none;"></div>

  <!-- Lien d'évitement pour l'accessibilité -->
  <a class="skip-link" href="#main-content">Aller au contenu principal</a>

  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <button id="scroll-top" aria-label="Retour en haut de la page">
    <span aria-hidden="true">↑</span>
  </button>

  <!-- Scripts différés pour éviter les longues tâches -->
  <script defer src="/js/main.js"></script>

  <!-- Google Analytics – en fin de body pour ne pas bloquer le LCP -->
  <script is:inline>
    (function() {
      var consent = localStorage.getItem('cookieConsent');
      if (consent === 'accept') {
        var script = document.createElement('script');
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-193H6KEEYR';
        script.async = true;
        document.head.appendChild(script);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-193H6KEEYR');
      }
    })();
  </script>
</body>
</html>